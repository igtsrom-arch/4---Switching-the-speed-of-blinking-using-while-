void setup() {
  DDRB |=  (1 << PB5);
  DDRB &= ~(1 << PB0);
  PORTB |=  (1 << PB0);
}
void loop() {
      while (!(PINB & (1 << PB0))) {
      PORTB |=  (1 << PB5);
      delay(100);
      PORTB &= ~(1 << PB5);
      delay(100);
    }
    PORTB |=  (1 << PB5);
    delay(1000);
    PORTB &= ~(1 << PB5);
    delay(1000);
}
